APP_NAME=Vedock
APP_SHORT_NAME=Vedock
CLI_NAME=vedock
APP_TAGLINE=Build any AI. No code. Full control.
APP_HOST=0.0.0.0
APP_PORT=5464
# local_compute keeps training and artifacts on this installation. A public
# control plane should use hosted_inference so training tasks wait for the
# authenticated owner's connected device.
NODE_MODE=local_compute
NODE_NAME=My Vedock Node
CONTROL_PLANE_URL=https://vedock.ecorims.com
SECRET_KEY=replace-this-before-sharing
# Leave these relative for a portable clone, or replace them with absolute
# paths owned by this Vedock installation.
DATABASE_URL=sqlite:///vedock.db
VEDOCK_STORAGE_ROOT=storage
VEDOCK_DISTRIBUTION_ROOT=distribution
# Optional read-only legacy model integration.
STORYMAKER_ROOT=
STORYMAKER_FINAL_PATH=
STORYMAKER_FINETUNED_PATH=
VEDOCK_RUNTIME_PYTHON=
MAX_UPLOAD_MB=100
URL_DOWNLOAD_MAX_MB=100
OFFLINE_MODE=false
MODEL_TRAINING_ENABLED=true
